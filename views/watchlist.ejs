<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Watchlist | Wysteria</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet"
  >
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
<%- include('./navbar.ejs') %>
<main class="page-shell">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <div class="eyebrow">
          PERSONAL COLLECTION
        </div>
        <h1 class="page-title">
          My Watchlist
        </h1>
        <p class="page-subtitle">
          Movies you saved for later.
        </p>
      </div>
      <span class="rating-pill">
        <i class="bi bi-bookmark-heart-fill"></i>
        <%= movies.length %>
      </span>
    </div>
    <% if(movies.length===0){ %>
      <div class="empty-state">
        <i class="bi bi-bookmark-x fs-1 text-warning"></i>
        <p class="mt-3 mb-0 text-muted">
          Your watchlist is empty.
        </p>
      </div>
    <% } %>
    <section class="movie-grid" aria-label="Saved movies">
      <% movies.forEach((movie)=>{ %>
        <% const posterPath = movie.posterPath || movie.Posterpath || movie.poster_path; %>
        <% const statusOptions = ['Plan to Watch', 'Watching', 'Completed', 'On hold', 'Dropped']; %>
        <article class="movie-card">
          <div class="dropdown card-menu">
            <button
              class="btn btn-outline-light card-menu-button"
              type="button"
              id="watchlistMenu<%= movie._id %>"
              data-bs-toggle="dropdown"
              aria-expanded="false"
              aria-label="Change watch status for <%= movie.title %>"
            >
              <i class="bi bi-three-dots"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end watch-status-menu" aria-labelledby="watchlistMenu<%= movie._id %>">
              <% statusOptions.forEach((statusOption) => { %>
                <form action="/watchlist/add" method="POST">
                  <input type="hidden" name="tmdbId" value="<%= movie.tmdbId %>">
                  <input type="hidden" name="title" value="<%= movie.title %>">
                  <input type="hidden" name="posterPath" value="<%= posterPath || '' %>">
                  <input type="hidden" name="status" value="<%= statusOption %>">
                  <button class="dropdown-item <%= movie.status === statusOption ? 'active' : '' %>">
                    <% if (movie.status === statusOption) { %>
                      <i class="bi bi-check2 me-2"></i>
                    <% } else { %>
                      <span class="status-menu-spacer"></span>
                    <% } %>
                    <%= statusOption %>
                  </button>
                </form>
              <% }) %>
            </div>
          </div>
          <div class="poster-frame">
            <% if (posterPath) { %>
              <img
                src="https://image.tmdb.org/t/p/w500<%= posterPath %>"
                class="movie-img"
                alt="<%= movie.title %> poster"
              >
            <% } else { %>
              <div class="poster-placeholder">
                <i class="bi bi-film"></i>
              </div>
            <% } %>
          </div>
          <div class="movie-card-body">
            <h3 class="movie-title">
              <%= movie.title %>
            </h3>
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="badge bg-warning text-dark">
                <%= movie.status ? movie.status.replace(/_/g, ' ') : 'plan to watch' %>
              </span>
            </div>
            <div class="d-flex gap-2">
              <a href="/movie/<%= movie.tmdbId %>" class="btn btn-outline-light btn-sm flex-fill">
                <i class="bi bi-eye me-1"></i>View
              </a>
              <form action="/watchlist/remove/<%= movie._id %>" method="POST" class="flex-fill">
                <button class="btn btn-danger btn-sm w-100"><i class="bi bi-trash me-1"></i>Remove</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    </section>
  </div>
</main>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"></script>
</body>
</html>
