<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Watchlist | Wysteria</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet"
  >
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link href="/styles.css" rel="stylesheet">
  <style>
    .watchlist-filter-bar {
      overflow-x: auto;
      scrollbar-width: none; /* Firefox */
      margin-bottom: 24px;
    }
    .watchlist-filter-bar::-webkit-scrollbar {
      display: none; /* Safari and Chrome */
    }
    .nav-tabs-wrapper {
      border-bottom: 1px solid var(--line);
      padding-bottom: 12px;
    }
    .watchlist-filter-bar .nav-pills {
      display: flex;
      flex-wrap: nowrap;
      gap: 8px;
    }
    .watchlist-filter-bar .nav-link {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--line);
      color: var(--muted);
      font-weight: 600;
      white-space: nowrap;
      transition: all 0.2s ease;
      border-radius: 8px;
      padding: 8px 16px;
    }
    .watchlist-filter-bar .nav-link:hover {
      background: rgba(255, 255, 255, 0.1);
      color: var(--text);
    }
    .watchlist-filter-bar .nav-link.active {
      background: linear-gradient(135deg, var(--gold), #fff0bb);
      color: #131721 !important;
      border-color: transparent;
      box-shadow: 0 4px 15px rgba(255, 209, 102, 0.25);
    }
    .watchlist-filter-bar .nav-link .badge {
      background-color: rgba(255, 255, 255, 0.12) !important;
      color: var(--muted);
    }
    .watchlist-filter-bar .nav-link.active .badge {
      background-color: rgba(19, 23, 33, 0.12) !important;
      color: #131721;
    }
  </style>
</head>
<body>
<%- include('./navbar.ejs') %>
<main class="page-shell">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <div class="eyebrow">
          PERSONAL COLLECTION
        </div>
        <h1 class="page-title">
          My Watchlist
        </h1>
        <p class="page-subtitle">
          Movies you saved for later.
        </p>
      </div>
      <span class="rating-pill">
        <i class="bi bi-bookmark-heart-fill"></i>
        <%= movies.length %>
      </span>
    </div>

    <% if(movies.length > 0) { %>
      <!-- Watchlist Filters/Tabs -->
      <div class="watchlist-filter-bar">
        <div class="nav-tabs-wrapper">
          <ul class="nav nav-pills" id="watchlistTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" data-filter="all" type="button">
                All <span class="badge rounded-pill ms-1"><%= movies.length %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-filter="Plan to Watch" type="button">
                Plan to Watch <span class="badge rounded-pill ms-1"><%= movies.filter(m => m.status === 'Plan to Watch').length %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-filter="Watching" type="button">
                Watching <span class="badge rounded-pill ms-1"><%= movies.filter(m => m.status === 'Watching').length %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-filter="Completed" type="button">
                Completed <span class="badge rounded-pill ms-1"><%= movies.filter(m => m.status === 'Completed').length %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-filter="On hold" type="button">
                On Hold <span class="badge rounded-pill ms-1"><%= movies.filter(m => m.status === 'On hold').length %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-filter="Dropped" type="button">
                Dropped <span class="badge rounded-pill ms-1"><%= movies.filter(m => m.status === 'Dropped').length %></span>
              </button>
            </li>
          </ul>
        </div>
      </div>
    <% } %>

    <% if(movies.length===0){ %>
      <div class="empty-state">
        <i class="bi bi-bookmark-x fs-1 text-warning"></i>
        <p class="mt-3 mb-0 text-muted">
          Your watchlist is empty.
        </p>
      </div>
    <% } %>

    <!-- Empty state for categories with no items -->
    <div id="emptyCategoryState" class="empty-state" style="display: none;">
      <i class="bi bi-folder-x fs-1 text-warning"></i>
      <p class="mt-3 mb-0 text-muted">
        No movies found in this status.
      </p>
    </div>

    <section class="movie-grid" aria-label="Saved movies">
      <% movies.forEach((movie)=>{ %>
        <% const posterPath = movie.posterPath || movie.Posterpath || movie.poster_path; %>
        <% const statusOptions = ['Plan to Watch', 'Watching', 'Completed', 'On hold', 'Dropped']; %>
        <article class="movie-card" data-status="<%= movie.status %>">
          <div class="dropdown card-menu">
            <button
              class="btn btn-outline-light card-menu-button"
              type="button"
              id="watchlistMenu<%= movie._id %>"
              data-bs-toggle="dropdown"
              aria-expanded="false"
              aria-label="Change watch status for <%= movie.title %>"
            >
              <i class="bi bi-three-dots"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end watch-status-menu" aria-labelledby="watchlistMenu<%= movie._id %>">
              <% statusOptions.forEach((statusOption) => { %>
                <form action="/watchlist/add" method="POST">
                  <input type="hidden" name="tmdbId" value="<%= movie.tmdbId %>">
                  <input type="hidden" name="title" value="<%= movie.title %>">
                  <input type="hidden" name="posterPath" value="<%= posterPath || '' %>">
                  <input type="hidden" name="status" value="<%= statusOption %>">
                  <input type="hidden" name="mediaType" value="<%= movie.mediaType || 'movie' %>">
                  <button class="dropdown-item <%= movie.status === statusOption ? 'active' : '' %>">
                    <% if (movie.status === statusOption) { %>
                      <i class="bi bi-check2 me-2"></i>
                    <% } else { %>
                      <span class="status-menu-spacer"></span>
                    <% } %>
                    <%= statusOption %>
                  </button>
                </form>
              <% }) %>
            </div>
          </div>
          <div class="poster-frame">
            <% if (posterPath) { %>
              <img
                src="https://image.tmdb.org/t/p/w500<%= posterPath %>"
                class="movie-img"
                alt="<%= movie.title %> poster"
              >
            <% } else { %>
              <div class="poster-placeholder">
                <i class="bi bi-film"></i>
              </div>
            <% } %>
          </div>
          <div class="movie-card-body">
            <h3 class="movie-title">
              <%= movie.title %>
            </h3>
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="badge bg-light text-dark">
                <%= movie.status ? movie.status.replace(/_/g, ' ') : 'plan to watch' %>
              </span>
              <span class="badge bg-secondary">
                <%= movie.mediaType === 'tv' ? 'TV' : 'Movie' %>
              </span>
            </div>
            <div class="d-flex gap-2">
              <a href="<%= movie.mediaType === 'tv' ? '/series/' + movie.tmdbId : '/movie/' + movie.tmdbId %>" class="btn btn-outline-light btn-sm flex-fill">
                <i class="bi bi-eye me-1"></i>View
              </a>
              <form action="/watchlist/remove/<%= movie._id %>" method="POST" class="flex-fill">
                <button class="btn btn-danger btn-sm w-100"><i class="bi bi-trash me-1"></i>Remove</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    </section>
  </div>
</main>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('#watchlistTabs button');
    const cards = document.querySelectorAll('.movie-card');
    const emptyCategoryState = document.getElementById('emptyCategoryState');
    const grid = document.querySelector('.movie-grid');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Remove active class from all tabs
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const filter = tab.getAttribute('data-filter');
        let visibleCount = 0;

        cards.forEach(card => {
          const status = card.getAttribute('data-status');
          if (filter === 'all' || status === filter) {
            card.style.display = 'block';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // Toggle category empty state message
        if (visibleCount === 0) {
          emptyCategoryState.style.display = 'flex';
          if (grid) grid.style.display = 'none';
        } else {
          emptyCategoryState.style.display = 'none';
          if (grid) grid.style.display = 'grid';
        }
      });
    });
  });
</script>
</body>
</html>
