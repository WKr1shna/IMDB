<nav class="navbar navbar-expand-lg navbar-dark app-navbar fixed-top">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" href="/">
      <img src="/favicon.png" alt="Wysteria Logo" class="navbar-brand-logo">
      <span>Wysteria</span>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-lg-auto ms-lg-4 my-3 my-lg-0">
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">
            <i class="bi bi-grid-3x3-gap me-1"></i> Browse
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/series') ? 'active' : '' %>" href="/series">
            <i class="bi bi-tv me-1"></i> Series
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/trending' ? 'active' : '' %>" href="/trending">
            <i class="bi bi-graph-up-arrow me-1"></i> Trending
          </a>
        </li>
      </ul>

      <form class="d-flex nav-search me-lg-3 mb-3 mb-lg-0" action="<%= currentPath.startsWith('/series') ? '/series' : '/' %>" method="GET">
        <div class="input-group">
          <input class="form-control" type="search" name="q" value="<%= searchQuery || '' %>" placeholder="<%= currentPath.startsWith('/series') ? 'Search series' : 'Search movies' %>" style="border-right: none; background: #1a1a1a; color: #fff; border-color: rgba(255,255,255,0.15);">
          <% if (currentPath === '/' || currentPath === '/series') { %>
            <button type="button" class="btn btn-outline-secondary d-flex align-items-center" data-bs-toggle="collapse" data-bs-target="#filter-panel-collapse" title="Toggle Filters" style="border-left: none; border-right: none; border-color: rgba(255,255,255,0.15); background: #1a1a1a; color: #888;">
              <i class="bi bi-funnel"></i>
            </button>
          <% } else { %>
            <a href="<%= currentPath.startsWith('/series') ? '/series?showFilters=true' : '/?showFilters=true' %>" class="btn btn-outline-secondary d-flex align-items-center" title="Advanced Filters" style="border-left: none; border-right: none; border-color: rgba(255,255,255,0.15); background: #1a1a1a; color: #888;">
              <i class="bi bi-funnel"></i>
            </a>
          <% } %>
          <button class="btn btn-outline-light" aria-label="Search" style="border-left: none;">
            <i class="bi bi-search"></i>
          </button>
        </div>
      </form>

      <div class="navbar-actions d-flex flex-wrap align-items-center gap-2">
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <div class="dropdown me-lg-2">
            <button class="btn btn-link text-light p-0 border-0 d-flex align-items-center gap-2 dropdown-toggle-custom" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
              <div class="avatar-circle bg-warning text-dark d-flex align-items-center justify-content-center fw-bold rounded-circle" style="width: 38px; height: 38px; font-size: 1.1rem; border: 2px solid rgba(255,255,255,0.2);">
                <%= currentUser.username.charAt(0).toUpperCase() %>
              </div>
            </button>
            <ul class="dropdown-menu dropdown-menu-end profile-dropdown-menu p-3" aria-labelledby="profileDropdown" style="min-width: 280px; background: #181824; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; color: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
              <li class="px-2 pb-3 mb-2 border-bottom border-secondary">
                <div class="fw-bold text-warning fs-5"><%= currentUser.username %></div>
                <div class="text-light-50 small text-truncate" style="opacity: 0.7;"><%= currentUser.email %></div>
              </li>
              <li>
                <a class="dropdown-item d-flex align-items-center gap-3 py-2 px-3 rounded-2 text-light" href="/profile">
                  <i class="bi bi-person fs-5"></i> Profile
                </a>
              </li>
              <li>
                <a class="dropdown-item d-flex align-items-center gap-3 py-2 px-3 rounded-2 text-light" href="/continue-watching">
                  <i class="bi bi-clock-history fs-5"></i> Continue Watching
                </a>
              </li>
              <li>
                <a class="dropdown-item d-flex align-items-center gap-3 py-2 px-3 rounded-2 text-light" href="/watchlist">
                  <i class="bi bi-heart fs-5"></i> Watch List
                </a>
              </li>
              <li>
                <a class="dropdown-item d-flex align-items-center gap-3 py-2 px-3 rounded-2 text-light" href="/settings">
                  <i class="bi bi-gear fs-5"></i> Settings
                </a>
              </li>
              <li class="mt-3 pt-2 border-top border-secondary d-flex justify-content-end">
                <a href="/logout" class="btn btn-link text-light text-decoration-none p-0 d-flex align-items-center gap-1 small" style="opacity: 0.85;">
                  Logout <i class="bi bi-box-arrow-right"></i>
                </a>
              </li>
            </ul>
          </div>
          
        <% } else { %>
          <a href="/login" class="btn btn-outline-light">
            Login
          </a>

          <a href="/signup" class="btn btn-warning">
            Signup
          </a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
