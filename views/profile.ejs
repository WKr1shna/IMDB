<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile | Wysteria</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('./navbar.ejs') %>

  <main class="page-shell">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <section class="form-panel p-5 rounded-3 mb-5" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px);">
            <div class="text-center mb-4">
              <div class="avatar-circle d-inline-flex align-items-center justify-content-center fw-bold rounded-circle mb-3" style="width: 80px; height: 80px; font-size: 2.2rem; border: 1px solid rgba(255,255,255,0.25); background: #ffffff; color: #000000;">
                <%= currentUser.username.charAt(0).toUpperCase() %>
              </div>
              <h1 class="page-title text-white"><%= currentUser.username %></h1>
              <p class="text-muted"><%= currentUser.email %></p>
            </div>

            <div class="row g-4 text-center mt-2">
              <div class="col-6">
                <div class="p-4 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04);">
                  <div class="display-5 fw-bold text-light"><%= watchlistCount %></div>
                  <div class="text-muted small uppercase-label mt-2">Watchlist Items</div>
                </div>
              </div>
              <div class="col-6">
                <div class="p-4 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04);">
                  <div class="display-5 fw-bold text-light"><%= reviewsCount %></div>
                  <div class="text-muted small uppercase-label mt-2">Reviews Written</div>
                </div>
              </div>
            </div>

            <div class="mt-5 border-top border-secondary pt-4">
              <h5 class="text-light mb-3">Account Details</h5>
              <div class="d-flex justify-content-between py-2 border-bottom border-secondary" style="border-color: rgba(255,255,255,0.05) !important;">
                <span class="text-muted">Username</span>
                <span class="text-light fw-bold"><%= currentUser.username %></span>
              </div>
              <div class="d-flex justify-content-between py-2 border-bottom border-secondary" style="border-color: rgba(255,255,255,0.05) !important;">
                <span class="text-muted">Email Address</span>
                <span class="text-light fw-bold"><%= currentUser.email %></span>
              </div>
              <div class="d-flex justify-content-between py-2">
                <span class="text-muted">Member Since</span>
                <span class="text-light fw-bold"><%= currentUser.createdAt ? new Date(currentUser.createdAt).toLocaleDateString() : 'N/A' %></span>
              </div>
            </div>
            
            <div class="text-center mt-5">
              <a href="/settings" class="btn btn-outline-light px-4 me-2">
                <i class="bi bi-gear me-1"></i> Edit Settings
              </a>
              <a href="/logout" class="btn btn-primary px-4">
                Logout <i class="bi bi-box-arrow-right"></i>
              </a>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"></script>
</body>
</html>
