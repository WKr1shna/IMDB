<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Watching <%= series.name %> - Season <%= currentSeason %>, Episode <%= currentEpisode %> | Wysteria</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link href="/styles.css" rel="stylesheet">
  <style>
    .watch-layout {
      display: grid;
      grid-template-columns: 3fr 1fr;
      gap: 24px;
    }

    @media (max-width: 991px) {
      .watch-layout {
        grid-template-columns: 1fr;
      }
    }

    .episode-sidebar {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 20px;
      backdrop-filter: blur(10px);
    }

    .episode-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(50px, 1fr));
      gap: 8px;
      max-height: 400px;
      overflow-y: auto;
      padding-right: 4px;
    }

    .episode-grid::-webkit-scrollbar {
      width: 6px;
    }

    .episode-grid::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.02);
    }

    .episode-grid::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 3px;
    }

    .episode-grid::-webkit-scrollbar-thumb:hover {
      background: rgba(255, 255, 255, 0.2);
    }
  </style>
</head>

<body>
  <%- include('./navbar.ejs') %>

    <% const activeSeason=series.seasons.find(s=> s.season_number === currentSeason) || series.seasons.find(s =>
      s.season_number > 0) || series.seasons[0];
      const episodeCount = activeSeason ? activeSeason.episode_count : 0;
      %>

      <main class="page-shell">
        <div class="container">
          <div class="mb-4">
            <nav aria-label="breadcrumb">
              <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="/series" class="text-muted text-decoration-none">Series</a></li>
                <li class="breadcrumb-item"><a href="/series/<%= series.id %>" class="text-muted text-decoration-none">
                    <%= series.name %>
                  </a></li>
                <li class="breadcrumb-item active text-warning" aria-current="page">Season <%= currentSeason %>, Episode
                    <%= currentEpisode %>
                </li>
              </ol>
            </nav>
            <h1 class="page-title h2">
              <%= series.name %>
            </h1>
            <p class="text-muted mb-0">Playing Season <%= currentSeason %>, Episode <%= currentEpisode %>: <%=
                    activeSeason ? activeSeason.name : '' %>
            </p>
          </div>

          <div class="watch-layout">
            <!-- Video Player Section -->
            <div class="video-container">
              <div class="ratio ratio-16x9 border border-secondary rounded overflow-hidden shadow-lg">
                <iframe id="player-iframe" src="<%= providers[0].url %>" frameborder="0" allowfullscreen
                  allow="autoplay; fullscreen" referrerpolicy="origin"></iframe>
              </div>
              <!-- Provider Selector Interface -->
              <div class="d-flex flex-wrap align-items-center gap-2 mt-4 justify-content-between p-3 rounded"
                style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                <div class="d-flex align-items-center gap-2">
                  <span class="text-muted small fw-bold text-uppercase"
                    style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-server me-1"></i> Streaming
                    Server:</span>
                  <div class="d-flex flex-wrap gap-2" id="provider-selectors"></div>
                </div>
                <div id="playback-status-toast" class="text-warning small d-none">
                  <i class="bi bi-arrow-repeat me-1"></i> Auto-switching server...
                </div>
              </div>
            </div>

            <!-- Season and Episode Selector Sidebar -->
            <div class="episode-sidebar">
              <h2 class="h5 mb-3 text-light"><i class="bi bi-collection-play me-2 text-warning"></i>Episodes</h2>

              <div class="mb-3">
                <label for="seasonSelect" class="form-label text-muted small">Select Season</label>
                <select id="seasonSelect" class="form-select bg-dark text-light border-secondary">
                  <% series.seasons.forEach((season)=> { %>
                    <% if (season.season_number> 0) { %>
                      <option value="<%= season.season_number %>" <%=currentSeason===season.season_number ? 'selected'
                        : '' %>>
                        <%= season.name %> (<%= season.episode_count %> eps)
                      </option>
                      <% } %>
                        <% }) %>
                </select>
              </div>

              <label class="form-label text-muted small">Select Episode</label>
              <div class="episode-grid">
                <% for (let ep=1; ep <=episodeCount; ep++) { %>
                  <a href="/watch-series/<%= series.id %>?season=<%= currentSeason %>&episode=<%= ep %>"
                    class="btn <%= currentEpisode === ep ? 'btn-danger' : 'btn-outline-light' %> btn-sm d-flex align-items-center justify-content-center"
                    style="height: 38px;">
                    <%= ep %>
                  </a>
                  <% } %>
              </div>
            </div>
          </div>
        </div>
      </main>

      <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"></script>
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const seasonSelect = document.getElementById('seasonSelect');
          if (seasonSelect) {
            seasonSelect.addEventListener('change', function () {
              window.location.href = `/watch-series/<%= series.id %>?season=${this.value}&episode=1`;
            });
          }
        });

        const providers = <%- JSON.stringify(providers) %>;
        let currentProviderIndex = 0;
        let lastSavedProgressTime = 0;
        let failoverTimer = null;
        let isPlaybackStarted = false;

        const iframe = document.getElementById("player-iframe");
        const playbackStatus = document.getElementById("playback-status-toast");
        const selectorsContainer = document.getElementById("provider-selectors");

        function initProviderSelectors() {
          selectorsContainer.innerHTML = "";
          providers.forEach((provider, idx) => {
            const btn = document.createElement("button");
            btn.className = `btn btn-sm ${idx === currentProviderIndex ? 'btn-warning text-dark fw-bold' : 'btn-outline-secondary text-light'}`;
            btn.style.borderRadius = "20px";
            btn.style.fontSize = "0.75rem";
            btn.style.padding = "4px 14px";
            btn.innerHTML = `<i class="bi bi-play-fill"></i> ${provider.name}`;
            btn.addEventListener("click", () => switchProvider(idx, true));
            selectorsContainer.appendChild(btn);
          });
        }

        function switchProvider(index, isManual = false) {
          if (index < 0 || index >= providers.length) {
            if (!isManual) showGlobalFailure();
            return;
          }

          currentProviderIndex = index;
          isPlaybackStarted = false;
          initProviderSelectors();

          let targetUrl = providers[index].url;
          // Resume from last known position when switching mid-playback
          if (lastSavedProgressTime > 10) {
            const sep = targetUrl.includes("?") ? "&" : "?";
            if (targetUrl.includes("vidking.net")) {
              targetUrl += `${sep}progress=${Math.floor(lastSavedProgressTime)}`;
            } else if (targetUrl.includes("vidlink.pro")) {
              targetUrl += `${sep}startAt=${Math.floor(lastSavedProgressTime)}`;
            } else {
              targetUrl += `${sep}t=${Math.floor(lastSavedProgressTime)}`;
            }
          }

          console.log(`[StreamingManager] Switching to provider: ${providers[index].name}`);
          iframe.src = targetUrl;
          startFailoverTimer();
        }

        function startFailoverTimer() {
          if (failoverTimer) clearTimeout(failoverTimer);
          failoverTimer = setTimeout(() => {
            if (!isPlaybackStarted) {
              const nextIndex = currentProviderIndex + 1;
              if (nextIndex < providers.length) {
                playbackStatus.classList.remove("d-none");
                playbackStatus.innerHTML = `<i class="bi bi-exclamation-triangle me-1"></i> ${providers[currentProviderIndex].name} failed. Trying ${providers[nextIndex].name}...`;
                setTimeout(() => {
                  playbackStatus.classList.add("d-none");
                  switchProvider(nextIndex, false);
                }, 1500);
              } else {
                showGlobalFailure();
              }
            }
          }, 15000);
        }

        function showGlobalFailure() {
          if (failoverTimer) clearTimeout(failoverTimer);
          const ratioDiv = document.querySelector(".ratio-16x9");
          if (ratioDiv) {
            ratioDiv.innerHTML = `
          <div class="d-flex flex-column align-items-center justify-content-center text-center p-5 rounded" style="background: rgba(255, 95, 109, 0.08); border: 1px solid rgba(255, 95, 109, 0.2); width: 100%; height: 100%;">
            <i class="bi bi-exclamation-octagon fs-1 text-danger mb-3"></i>
            <h3 class="text-light">This title is temporarily unavailable</h3>
            <p class="text-muted small mb-0">Please try again later. We apologize for the inconvenience.</p>
          </div>
        `;
          }
        }

        // ── iframe load/error detection ────────────────────────────────────
        iframe.addEventListener("load", function () {
          // For providers that don't send postMessage (non-VidKing),
          // treat a successful iframe load as playback started.
          const currentUrl = providers[currentProviderIndex].url;
          if (!currentUrl.includes("vidking.net")) {
            console.log(`[StreamingManager] iframe loaded for ${providers[currentProviderIndex].name}`);
            isPlaybackStarted = true;
            if (failoverTimer) {
              clearTimeout(failoverTimer);
              failoverTimer = null;
            }
          }
        });

        iframe.addEventListener("error", function () {
          console.log(`[StreamingManager] iframe error for ${providers[currentProviderIndex].name}`);
          const nextIndex = currentProviderIndex + 1;
          if (nextIndex < providers.length) {
            switchProvider(nextIndex, false);
          } else {
            showGlobalFailure();
          }
        });

        window.addEventListener("message", function (event) {
          try {
            const payload = JSON.parse(event.data);
            if (payload.type === "PLAYER_EVENT" && payload.data) {
              const { event: playerEvent, currentTime, duration, progress, id, mediaType, season, episode } = payload.data;

              if (playerEvent === 'timeupdate' || playerEvent === 'play') {
                isPlaybackStarted = true;
                if (failoverTimer) {
                  clearTimeout(failoverTimer);
                  failoverTimer = null;
                }
                if (currentTime) {
                  lastSavedProgressTime = currentTime;
                }
              }

              if (playerEvent === 'timeupdate' || playerEvent === 'pause' || playerEvent === 'ended') {
                fetch('/api/watch-progress', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({
                    tmdbId: id,
                    mediaType: mediaType,
                    title: '<%= series.name %>',
                    posterPath: '<%= series.poster_path %>',
                    progress: progress,
                    currentTime: currentTime,
                    duration: duration,
                    season: season,
                    episode: episode
                  })
                }).catch(err => console.error('Failed to report watch progress:', err));
              }
            }
          // VidLink-specific postMessage events
          if (payload.event === 'progress' && payload.currentTime) {
            isPlaybackStarted = true;
            if (failoverTimer) { clearTimeout(failoverTimer); failoverTimer = null; }
            lastSavedProgressTime = payload.currentTime;
          }
          } catch (e) {
            // Ignore parsing errors
          }
        });

        initProviderSelectors();
        startFailoverTimer();
      </script>
</body>

</html>