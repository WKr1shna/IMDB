<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle || 'Wysteria' %></title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('./navbar.ejs') %>

  <% const carouselMovies = currentPath === '/' && !searchQuery ? allMovies.filter(movie => movie.backdrop_path || movie.poster_path).slice(0, 5) : []; %>
  <% const surpriseMovies = currentPath === '/' && !searchQuery && typeof randomMovies !== 'undefined' ? randomMovies : []; %>

  <main class="page-shell">
    <div class="container">
      <% if (carouselMovies.length > 0) { %>
        <section class="home-carousel" aria-label="Featured movies">
          <div id="homeMovieCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
              <% carouselMovies.forEach((movie, index) => { %>
                <button
                  type="button"
                  data-bs-target="#homeMovieCarousel"
                  data-bs-slide-to="<%= index %>"
                  class="<%= index === 0 ? 'active' : '' %>"
                  aria-current="<%= index === 0 ? 'true' : 'false' %>"
                  aria-label="Slide <%= index + 1 %>"
                ></button>
              <% }) %>
            </div>

            <div class="carousel-inner">
              <% carouselMovies.forEach((movie, index) => { %>
                <% const backdrop = movie.backdrop_path || movie.poster_path; %>
                <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                  <div
                    class="featured-slide"
                    style="background-image: url('https://image.tmdb.org/t/p/original<%= backdrop %>');"
                  >
                    <div class="featured-slide-content">
                      <% if (movie.poster_path) { %>
                        <img
                          src="https://image.tmdb.org/t/p/w342<%= movie.poster_path %>"
                          alt="<%= movie.title %> poster"
                          class="featured-poster"
                        >
                      <% } %>

                      <div class="featured-copy">
                        <div class="eyebrow">Featured Now</div>
                        <h2><%= movie.title %></h2>
                        <p>
                          <%= movie.overview ? movie.overview.slice(0, 180) + (movie.overview.length > 180 ? '...' : '') : 'Discover ratings, reviews, and details for this movie.' %>
                        </p>
                        <div class="featured-meta">
                          <span>
                            <i class="bi bi-calendar3"></i>
                            <%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>
                          </span>
                          <span>
                            <i class="bi bi-star-fill"></i>
                            <%= movie.vote_average ? movie.vote_average.toFixed(1) : '0.0' %>
                          </span>
                        </div>
                        <a href="/movie/<%= movie.id %>" class="btn btn-primary">
                          <i class="bi bi-eye me-1"></i> View Details
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#homeMovieCarousel" data-bs-slide="prev" aria-label="Previous movie">
              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#homeMovieCarousel" data-bs-slide="next" aria-label="Next movie">
              <span class="carousel-control-next-icon" aria-hidden="true"></span>
            </button>
          </div>
        </section>
      <% } %>

      <% if (surpriseMovies.length > 0) { %>
        <section class="random-movies-section" aria-label="Random movie recommendations">
          <div class="section-header compact-section-header">
            <div>
              <div class="eyebrow">Fresh Mix</div>
              <h1 class="random-section-title">Surprise Picks</h1>
              <p class="page-subtitle">A rotating set of well-loved movies from different corners of the library.</p>
            </div>
          </div>

          <div class="random-movie-grid">
            <% for (let movie of surpriseMovies) { %>
              <article class="movie-card random-movie-card">
                <div class="poster-frame">
                  <% if (movie.poster_path) { %>
                    <img
                      src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
                      class="movie-img"
                      alt="<%= movie.title %> poster"
                    >
                  <% } else { %>
                    <div class="poster-placeholder">
                      <i class="bi bi-film"></i>
                    </div>
                  <% } %>
                </div>
                <div class="movie-card-body">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                      <h2 class="movie-title">
                        <%= movie.title %>
                      </h2>
                      <div class="movie-meta">
                        <%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>
                      </div>
                    </div>
                    <span class="rating-pill">
                      <i class="bi bi-star-fill"></i>
                      <%= movie.avgRating ? movie.avgRating.toFixed(1) : '0.0' %>
                    </span>
                  </div>
                  <a href="/movie/<%= movie.id %>" class="btn btn-primary mt-auto">
                    <i class="bi bi-eye me-1"></i> View Details
                  </a>
                </div>
              </article>
            <% } %>
          </div>
        </section>
      <% } %>

      <section class="section-header">
        <div>
          <div class="eyebrow">Wysteria Library</div>
          <h1 class="page-title"><%= pageTitle || 'Browse Movies' %></h1>
          <p class="page-subtitle"><%= pageSubtitle || 'Rate films, read quick reactions, and find your next watch.' %></p>
        </div>
      </section>

      <% if (allMovies.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-film fs-1 text-warning"></i>
          <h2 class="h4 mt-3">No movies found</h2>
          <p class="text-muted mb-3">Try another search.</p>
        </div>
      <% } %>
      <section class="movie-grid" aria-label="Movies">
        <% for (let movie of allMovies) { %>
          <article class="movie-card">
            <div class="poster-frame">
              <% if (movie.poster_path) { %>
                <img
                  src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
                  class="movie-img"
                  alt="<%= movie.title %> poster"
                >
              <% } else { %>
                <div class="poster-placeholder">
                  <i class="bi bi-film"></i>
                </div>
              <% } %>
            </div>
            <div class="movie-card-body">
              <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                  <h2 class="movie-title">
                    <%= movie.title %>
                  </h2>
                  <div class="movie-meta">
                    <%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>
                  </div>
                </div>
                <span class="rating-pill">
                  <i class="bi bi-star-fill"></i>
                  <%= movie.avgRating ? movie.avgRating.toFixed(1) : '0.0' %>
                </span>
              </div>
              <a href="/movie/<%= movie.id %>" class="btn btn-primary mt-auto">
                <i class="bi bi-eye me-1"></i> View Details
              </a>
            </div>
          </article>
        <% } %>
      </section>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"></script>
</body>
</html>
