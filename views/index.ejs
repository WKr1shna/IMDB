<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle || 'Wysteria' %></title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('./navbar.ejs') %>

  <% const carouselMovies = currentPath === '/' && !searchQuery ? allMovies.filter(movie => movie.backdrop_path || movie.poster_path).slice(0, 5) : []; %>
  <% const surpriseMovies = currentPath === '/' && !searchQuery && typeof randomMovies !== 'undefined' ? randomMovies : []; %>

  <main class="page-shell">
    <div class="container">
      <% if (carouselMovies.length > 0) { %>
        <section class="home-carousel" aria-label="Featured movies">
          <div id="homeMovieCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
              <% carouselMovies.forEach((movie, index) => { %>
                <button
                  type="button"
                  data-bs-target="#homeMovieCarousel"
                  data-bs-slide-to="<%= index %>"
                  class="<%= index === 0 ? 'active' : '' %>"
                  aria-current="<%= index === 0 ? 'true' : 'false' %>"
                  aria-label="Slide <%= index + 1 %>"
                ></button>
              <% }) %>
            </div>

            <div class="carousel-inner">
              <% carouselMovies.forEach((movie, index) => { %>
                <% const backdrop = movie.backdrop_path || movie.poster_path; %>
                <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                  <div
                    class="featured-slide"
                    style="background-image: url('https://image.tmdb.org/t/p/original<%= backdrop %>');"
                  >
                    <div class="featured-slide-content">
                      <% if (movie.poster_path) { %>
                        <img
                          src="https://image.tmdb.org/t/p/w342<%= movie.poster_path %>"
                          alt="<%= movie.title %> poster"
                          class="featured-poster"
                        >
                      <% } %>

                      <div class="featured-copy">
                        <div class="eyebrow">Featured Now</div>
                        <h2><%= movie.title %></h2>
                        <p>
                          <%= movie.overview ? movie.overview.slice(0, 180) + (movie.overview.length > 180 ? '...' : '') : 'Discover ratings, reviews, and details for this movie.' %>
                        </p>
                        <div class="featured-meta">
                          <span>
                            <i class="bi bi-calendar3"></i>
                            <%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>
                          </span>
                          <span>
                            <i class="bi bi-star-fill"></i>
                            <%= movie.vote_average ? movie.vote_average.toFixed(1) : '0.0' %>
                          </span>
                        </div>
                        <a href="/movie/<%= movie.id %>" class="btn btn-primary">
                          <i class="bi bi-eye me-1"></i> View Details
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#homeMovieCarousel" data-bs-slide="prev" aria-label="Previous movie">
              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#homeMovieCarousel" data-bs-slide="next" aria-label="Next movie">
              <span class="carousel-control-next-icon" aria-hidden="true"></span>
            </button>
          </div>
        </section>
      <% } %>

      <% if (surpriseMovies.length > 0) { %>
        <section class="random-movies-section" aria-label="Random movie recommendations">
          <div class="section-header compact-section-header">
            <div>
              <div class="eyebrow">Fresh Mix</div>
              <h1 class="random-section-title">Surprise Picks</h1>
              <p class="page-subtitle">A rotating set of well-loved movies from different corners of the library.</p>
            </div>
          </div>

          <div class="random-movie-grid">
            <% for (let movie of surpriseMovies) { %>
              <article class="movie-card random-movie-card">
                <div class="poster-frame">
                  <% if (movie.poster_path) { %>
                    <img
                      src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
                      class="movie-img"
                      alt="<%= movie.title %> poster"
                    >
                  <% } else { %>
                    <div class="poster-placeholder">
                      <i class="bi bi-film"></i>
                    </div>
                  <% } %>
                </div>
                <div class="movie-card-body">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                      <h2 class="movie-title">
                        <%= movie.title %>
                      </h2>
                      <div class="movie-meta">
                        <%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>
                      </div>
                    </div>
                    <span class="rating-pill">
                      <i class="bi bi-star-fill"></i>
                      <%= movie.avgRating ? movie.avgRating.toFixed(1) : '0.0' %>
                    </span>
                  </div>
                  <a href="/movie/<%= movie.id %>" class="btn btn-primary mt-auto">
                    <i class="bi bi-eye me-1"></i> View Details
                  </a>
                </div>
              </article>
            <% } %>
          </div>
        </section>
      <% } %>

      <section class="section-header">
        <div>
          <div class="eyebrow">Wysteria Library</div>
          <h1 class="page-title"><%= pageTitle || 'Browse Movies' %></h1>
          <p class="page-subtitle"><%= pageSubtitle || 'Rate films, read quick reactions, and find your next watch.' %></p>
        </div>
      </section>

      <!-- Advanced Filter Panel -->
      <div class="collapse <%= (selectedGenre || selectedYear || searchQuery || showFilters) ? 'show' : '' %>" id="filter-panel-collapse">
        <div class="filter-panel mb-5 p-4 rounded-3" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px);">
          <form action="/" method="GET" class="row g-3 align-items-end">
            <div class="col-12 col-md-4 col-lg-3">
              <label class="form-label text-muted fw-bold small uppercase-label" style="font-size: 0.75rem; letter-spacing: 1px;">Search</label>
              <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="q" value="<%= searchQuery || '' %>" class="form-control bg-dark text-light border-secondary" placeholder="Search movies...">
              </div>
            </div>
            
            <div class="col-6 col-md-3 col-lg-3">
              <label class="form-label text-muted fw-bold small uppercase-label" style="font-size: 0.75rem; letter-spacing: 1px;">Genres</label>
              <select name="genre" class="form-select bg-dark text-light border-secondary" onchange="this.form.submit()">
                <option value="">Any</option>
                <option value="28" <%= selectedGenre === '28' ? 'selected' : '' %>>Action</option>
                <option value="12" <%= selectedGenre === '12' ? 'selected' : '' %>>Adventure</option>
                <option value="16" <%= selectedGenre === '16' ? 'selected' : '' %>>Animation</option>
                <option value="35" <%= selectedGenre === '35' ? 'selected' : '' %>>Comedy</option>
                <option value="80" <%= selectedGenre === '80' ? 'selected' : '' %>>Crime</option>
                <option value="99" <%= selectedGenre === '99' ? 'selected' : '' %>>Documentary</option>
                <option value="18" <%= selectedGenre === '18' ? 'selected' : '' %>>Drama</option>
                <option value="10751" <%= selectedGenre === '10751' ? 'selected' : '' %>>Family</option>
                <option value="14" <%= selectedGenre === '14' ? 'selected' : '' %>>Fantasy</option>
                <option value="36" <%= selectedGenre === '36' ? 'selected' : '' %>>History</option>
                <option value="27" <%= selectedGenre === '27' ? 'selected' : '' %>>Horror</option>
                <option value="9648" <%= selectedGenre === '9648' ? 'selected' : '' %>>Mystery</option>
                <option value="10749" <%= selectedGenre === '10749' ? 'selected' : '' %>>Romance</option>
                <option value="878" <%= selectedGenre === '878' ? 'selected' : '' %>>Science Fiction</option>
                <option value="53" <%= selectedGenre === '53' ? 'selected' : '' %>>Thriller</option>
                <option value="37" <%= selectedGenre === '37' ? 'selected' : '' %>>Western</option>
              </select>
            </div>
            
            <div class="col-6 col-md-2 col-lg-2">
              <label class="form-label text-muted fw-bold small uppercase-label" style="font-size: 0.75rem; letter-spacing: 1px;">Year</label>
              <select name="year" class="form-select bg-dark text-light border-secondary" onchange="this.form.submit()">
                <option value="">Any</option>
                <% const currentYear = new Date().getFullYear(); %>
                <% for (let y = currentYear; y >= 2000; y--) { %>
                  <option value="<%= y %>" <%= selectedYear === String(y) ? 'selected' : '' %>><%= y %></option>
                <% } %>
              </select>
            </div>
            
            <div class="col-12 col-md-3 col-lg-3">
              <label class="form-label text-muted fw-bold small uppercase-label" style="font-size: 0.75rem; letter-spacing: 1px;">Sort</label>
              <select name="sort" class="form-select bg-dark text-light border-secondary" onchange="this.form.submit()">
                <option value="popularity.desc" <%= selectedSort === 'popularity.desc' ? 'selected' : '' %>>Popularity</option>
                <option value="vote_average.desc" <%= selectedSort === 'vote_average.desc' ? 'selected' : '' %>>Rating</option>
                <option value="release_date.desc" <%= selectedSort === 'release_date.desc' ? 'selected' : '' %>>Release Date</option>
              </select>
            </div>
          </form>
        </div>
      </div>

      <% if (allMovies.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-film fs-1 text-warning"></i>
          <h2 class="h4 mt-3">No movies found</h2>
          <p class="text-muted mb-3">Try another search.</p>
        </div>
      <% } %>
      <section class="movie-grid" aria-label="Movies">
        <% for (let movie of allMovies) { %>
          <article class="movie-card">
            <div class="poster-frame">
              <% if (movie.poster_path) { %>
                <img
                  src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
                  class="movie-img"
                  alt="<%= movie.title %> poster"
                >
              <% } else { %>
                <div class="poster-placeholder">
                  <i class="bi bi-film"></i>
                </div>
              <% } %>
            </div>
            <div class="movie-card-body">
              <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                  <h2 class="movie-title">
                    <%= movie.title %>
                  </h2>
                  <div class="movie-meta">
                    <%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>
                  </div>
                </div>
                <span class="rating-pill">
                  <i class="bi bi-star-fill"></i>
                  <%= movie.avgRating ? movie.avgRating.toFixed(1) : '0.0' %>
                </span>
              </div>
              <a href="/movie/<%= movie.id %>" class="btn btn-primary mt-auto">
                <i class="bi bi-eye me-1"></i> View Details
              </a>
            </div>
          </article>
        <% } %>
      </section>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"></script>
</body>
</html>
