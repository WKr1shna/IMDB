<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle || 'Wysteria Series' %></title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('./navbar.ejs') %>

  <% const carouselSeries = typeof allSeries !== 'undefined' && currentPath === '/series' && !searchQuery ? allSeries.filter(series => series.backdrop_path || series.poster_path).slice(0, 5) : []; %>
  <% const surpriseSeries = typeof allSeries !== 'undefined' && currentPath === '/series' && !searchQuery && typeof randomSeries !== 'undefined' ? randomSeries : []; %>

  <main class="page-shell">
    <div class="container">
      <% if (carouselSeries.length > 0) { %>
        <section class="home-carousel" aria-label="Featured series">
          <div id="homeSeriesCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
              <% carouselSeries.forEach((series, index) => { %>
                <button
                  type="button"
                  data-bs-target="#homeSeriesCarousel"
                  data-bs-slide-to="<%= index %>"
                  class="<%= index === 0 ? 'active' : '' %>"
                  aria-current="<%= index === 0 ? 'true' : 'false' %>"
                  aria-label="Slide <%= index + 1 %>"
                ></button>
              <% }) %>
            </div>

            <div class="carousel-inner">
              <% carouselSeries.forEach((series, index) => { %>
                <% const backdrop = series.backdrop_path || series.poster_path; %>
                <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                  <div
                    class="featured-slide"
                    style="background-image: url('https://image.tmdb.org/t/p/original<%= backdrop %>');"
                  >
                    <div class="featured-slide-content">
                      <% if (series.poster_path) { %>
                        <img
                          src="https://image.tmdb.org/t/p/w342<%= series.poster_path %>"
                          alt="<%= series.name %> poster"
                          class="featured-poster"
                        >
                      <% } %>

                      <div class="featured-copy">
                        <div class="eyebrow">Featured Now</div>
                        <h2><%= series.name %></h2>
                        <p>
                          <%= series.overview ? series.overview.slice(0, 180) + (series.overview.length > 180 ? '...' : '') : 'Discover ratings, reviews, and details for this series.' %>
                        </p>
                        <div class="featured-meta">
                          <span>
                            <i class="bi bi-calendar3"></i>
                            <%= series.first_air_date ? series.first_air_date.split('-')[0] : 'N/A' %>
                          </span>
                          <span>
                            <i class="bi bi-star-fill"></i>
                            <%= series.vote_average ? series.vote_average.toFixed(1) : '0.0' %>
                          </span>
                        </div>
                        <a href="/series/<%= series.id %>" class="btn btn-primary">
                          <i class="bi bi-eye me-1"></i> View Details
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#homeSeriesCarousel" data-bs-slide="prev" aria-label="Previous series">
              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#homeSeriesCarousel" data-bs-slide="next" aria-label="Next series">
              <span class="carousel-control-next-icon" aria-hidden="true"></span>
            </button>
          </div>
        </section>
      <% } %>

      <% if (surpriseSeries.length > 0) { %>
        <section class="random-movies-section" aria-label="Random series recommendations">
          <div class="section-header compact-section-header">
            <div>
              <div class="eyebrow">Fresh Mix</div>
              <h1 class="random-section-title">Surprise Picks</h1>
              <p class="page-subtitle">A rotating set of well-loved TV shows from different corners of the library.</p>
            </div>
          </div>

          <div class="random-movie-grid">
            <% for (let series of surpriseSeries) { %>
              <article class="movie-card random-movie-card">
                <div class="poster-frame">
                  <% if (series.poster_path) { %>
                    <img
                      src="https://image.tmdb.org/t/p/w500<%= series.poster_path %>"
                      class="movie-img"
                      alt="<%= series.name %> poster"
                    >
                  <% } else { %>
                    <div class="poster-placeholder">
                      <i class="bi bi-tv animate-flicker"></i>
                    </div>
                  <% } %>
                </div>
                <div class="movie-card-body">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                      <h2 class="movie-title">
                        <%= series.name %>
                      </h2>
                      <div class="movie-meta">
                        <%= series.first_air_date ? series.first_air_date.split('-')[0] : 'N/A' %>
                      </div>
                    </div>
                    <span class="rating-pill">
                      <i class="bi bi-star-fill"></i>
                      <%= series.avgRating ? series.avgRating.toFixed(1) : '0.0' %>
                    </span>
                  </div>
                  <a href="/series/<%= series.id %>" class="btn btn-primary mt-auto">
                    <i class="bi bi-eye me-1"></i> View Details
                  </a>
                </div>
              </article>
            <% } %>
          </div>
        </section>
      <% } %>

      <section class="section-header">
        <div>
          <div class="eyebrow">Wysteria Library</div>
          <h1 class="page-title"><%= pageTitle || 'Browse TV Series' %></h1>
          <p class="page-subtitle"><%= pageSubtitle || 'Track shows, write thoughts, and stream episodes.' %></p>
        </div>
      </section>

      <!-- Advanced Filter Panel -->
      <div class="collapse <%= (selectedGenre || selectedYear || searchQuery || showFilters) ? 'show' : '' %>" id="filter-panel-collapse">
        <div class="filter-panel mb-5 p-4 rounded-3" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px);">
          <form action="/series" method="GET" class="row g-3 align-items-end">
            <div class="col-12 col-md-4 col-lg-3">
              <label class="form-label text-muted fw-bold small uppercase-label" style="font-size: 0.75rem; letter-spacing: 1px;">Search</label>
              <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="q" value="<%= searchQuery || '' %>" class="form-control bg-dark text-light border-secondary" placeholder="Search series...">
              </div>
            </div>
            
            <div class="col-6 col-md-3 col-lg-3">
              <label class="form-label text-muted fw-bold small uppercase-label" style="font-size: 0.75rem; letter-spacing: 1px;">Genres</label>
              <select name="genre" class="form-select bg-dark text-light border-secondary" onchange="this.form.submit()">
                <option value="">Any</option>
                <option value="10759" <%= selectedGenre === '10759' ? 'selected' : '' %>>Action & Adventure</option>
                <option value="16" <%= selectedGenre === '16' ? 'selected' : '' %>>Animation</option>
                <option value="35" <%= selectedGenre === '35' ? 'selected' : '' %>>Comedy</option>
                <option value="80" <%= selectedGenre === '80' ? 'selected' : '' %>>Crime</option>
                <option value="99" <%= selectedGenre === '99' ? 'selected' : '' %>>Documentary</option>
                <option value="18" <%= selectedGenre === '18' ? 'selected' : '' %>>Drama</option>
                <option value="10751" <%= selectedGenre === '10751' ? 'selected' : '' %>>Family</option>
                <option value="10762" <%= selectedGenre === '10762' ? 'selected' : '' %>>Kids</option>
                <option value="9648" <%= selectedGenre === '9648' ? 'selected' : '' %>>Mystery</option>
                <option value="10763" <%= selectedGenre === '10763' ? 'selected' : '' %>>News</option>
                <option value="10764" <%= selectedGenre === '10764' ? 'selected' : '' %>>Reality</option>
                <option value="10765" <%= selectedGenre === '10765' ? 'selected' : '' %>>Sci-Fi & Fantasy</option>
                <option value="10766" <%= selectedGenre === '10766' ? 'selected' : '' %>>Soap</option>
                <option value="10767" <%= selectedGenre === '10767' ? 'selected' : '' %>>Talk</option>
                <option value="10768" <%= selectedGenre === '10768' ? 'selected' : '' %>>War & Politics</option>
                <option value="37" <%= selectedGenre === '37' ? 'selected' : '' %>>Western</option>
              </select>
            </div>
            
            <div class="col-6 col-md-2 col-lg-2">
              <label class="form-label text-muted fw-bold small uppercase-label" style="font-size: 0.75rem; letter-spacing: 1px;">Year</label>
              <select name="year" class="form-select bg-dark text-light border-secondary" onchange="this.form.submit()">
                <option value="">Any</option>
                <% const currentYear = new Date().getFullYear(); %>
                <% for (let y = currentYear; y >= 2000; y--) { %>
                  <option value="<%= y %>" <%= selectedYear === String(y) ? 'selected' : '' %>><%= y %></option>
                <% } %>
              </select>
            </div>
            
            <div class="col-12 col-md-3 col-lg-3">
              <label class="form-label text-muted fw-bold small uppercase-label" style="font-size: 0.75rem; letter-spacing: 1px;">Sort</label>
              <select name="sort" class="form-select bg-dark text-light border-secondary" onchange="this.form.submit()">
                <option value="popularity.desc" <%= selectedSort === 'popularity.desc' ? 'selected' : '' %>>Popularity</option>
                <option value="vote_average.desc" <%= selectedSort === 'vote_average.desc' ? 'selected' : '' %>>Rating</option>
                <option value="first_air_date.desc" <%= selectedSort === 'first_air_date.desc' ? 'selected' : '' %>>Release Date</option>
              </select>
            </div>
          </form>
        </div>
      </div>

      <% if (allSeries.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-tv fs-1 text-warning"></i>
          <h2 class="h4 mt-3">No series found</h2>
          <p class="text-muted mb-3">Try another search.</p>
        </div>
      <% } %>
      <section class="movie-grid" aria-label="TV Series">
        <% for (let series of allSeries) { %>
          <article class="movie-card">
            <div class="poster-frame">
              <% if (series.poster_path) { %>
                <img
                  src="https://image.tmdb.org/t/p/w500<%= series.poster_path %>"
                  class="movie-img"
                  alt="<%= series.name %> poster"
                >
              <% } else { %>
                <div class="poster-placeholder">
                  <i class="bi bi-tv"></i>
                </div>
              <% } %>
            </div>
            <div class="movie-card-body">
              <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                  <h2 class="movie-title">
                    <%= series.name %>
                  </h2>
                  <div class="movie-meta">
                    <%= series.first_air_date ? series.first_air_date.split('-')[0] : 'N/A' %>
                  </div>
                </div>
                <span class="rating-pill">
                  <i class="bi bi-star-fill"></i>
                  <%= series.avgRating ? series.avgRating.toFixed(1) : '0.0' %>
                </span>
              </div>
              <a href="/series/<%= series.id %>" class="btn btn-primary mt-auto">
                <i class="bi bi-eye me-1"></i> View Details
              </a>
            </div>
          </article>
        <% } %>
      </section>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"></script>
</body>
</html>
